# 必填：用于签发 JWT，生产环境请使用随机长字符串
# 生成方式：openssl rand -hex 32
JWT_SECRET=change-me-in-production

# 可选：数据库路径（默认 /data/finarch.db）
# FINARCH_DB=/data/finarch.db

# 可选：监听地址（默认 127.0.0.1:8080）
# FINARCH_ADDR=127.0.0.1:8080

# 可选：Cloudflare Turnstile 人机验证
# 前往 https://dash.cloudflare.com/?to=/:account/turnstile 创建站点获取密钥
# 留空则禁用验证（适合内网/本地部署）
TURNSTILE_SECRET=
TURNSTILE_SITE_KEY=
