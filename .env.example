# 必填：用于签发 JWT，生产环境请使用至少 32 字符的随机长字符串
# 生成方式：openssl rand -hex 32
JWT_SECRET=

# 必填：部署的镜像标签。生产环境使用 sha-<commit sha>，不要使用 latest
FINARCH_IMAGE_TAG=

# 可选：数据库路径（默认 /data/finarch.db）
# FINARCH_DB=/data/finarch.db

# 可选：监听地址（默认 127.0.0.1:8080）
# FINARCH_ADDR=127.0.0.1:8080

# 可选：SQLite 连接池调优（默认适合 WAL 单实例部署）
# FINARCH_DB_MAX_OPEN_CONNS=8
# FINARCH_DB_MAX_IDLE_CONNS=4
# FINARCH_DB_CONN_MAX_IDLE_TIME=5m
# FINARCH_DB_CONN_MAX_LIFETIME=30m

# 可选：Cloudflare Turnstile 人机验证
# 前往 https://dash.cloudflare.com/?to=/:account/turnstile 创建站点获取密钥
# 留空则禁用验证（适合内网/本地部署）
TURNSTILE_SECRET=
TURNSTILE_SITE_KEY=
