# 必填：用于签发 JWT，生产环境请使用随机长字符串
# 生成方式：openssl rand -hex 32
JWT_SECRET=change-me-in-production

# 可选：数据库路径（默认 /data/finarch.db）
# FINARCH_DB=/data/finarch.db

# 可选：监听地址（默认 127.0.0.1:8080）
# FINARCH_ADDR=127.0.0.1:8080

# 可选：Cloudflare Turnstile 人机验证（留空则跳过验证，适合本地开发）
# 申请地址：https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SECRET=0x...    # 后端密钥（保密，不要提交到 Git）
# TURNSTILE_SITE_KEY=0x...  # 前端站点密钥（可公开，前端用于展示 Widget）
